# Local Development Environment Variables
# Copy this to .env and fill in values

# MySQL (local)
MYSQL_URL=jdbc:mysql://localhost:3306/job_portal
MYSQL_USER=root
MYSQL_PASSWORD=root123

# JWT Secret (generate a random 256-bit key for production)
JWT_SECRET=yourSuperSecretKeyThatIsAtLeast256BitsLong12345

# Gmail SMTP
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_specific_password

# Hibernate
DDL_AUTO=update
SHOW_SQL=true
